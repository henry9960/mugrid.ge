# ─────────────────────────────────────────────────
# Admin CMS authentication
# Copy this file to .env.local and fill in values.
# ─────────────────────────────────────────────────

# PBKDF2 hash of your admin password.
# Generate one with:
#   node -e "
#     const c=require('crypto'), pw='your-password-here'
#     const s=c.randomBytes(16).toString('hex')
#     const h=c.pbkdf2Sync(pw,s,100000,32,'sha256').toString('hex')
#     console.log('pbkdf2:sha256:100000:'+s+':'+h)
#   "
ADMIN_PASSWORD_HASH=pbkdf2:sha256:100000:<salt>:<hash>

# Random secret stored in the session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace-with-64-char-random-hex-string

# ─────────────────────────────────────────────────
# GitHub API — required on Vercel so admin saves
# commit content back to the repo (triggering redeploy).
# Not needed for local dev (falls back to filesystem).
# ─────────────────────────────────────────────────

# Personal Access Token with "Contents: read & write" permission on this repo.
# Create at: https://github.com/settings/tokens?type=beta (Fine-grained, repo scope)
GITHUB_TOKEN=github_pat_...

GITHUB_OWNER=henry9960
GITHUB_REPO=mugrid.ge
# GITHUB_BRANCH=main   # defaults to main

# ─────────────────────────────────────────────────
# Vercel Blob — required on Vercel for logo/image uploads.
# Automatically set by Vercel when you add a Blob store.
# Not needed for local dev.
# ─────────────────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=vercel_blob_...
